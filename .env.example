# ---------------------------------------------------------------------------
# Aneem — environment variables
# Copy to .env.local for local dev, or set in Vercel Project Settings.
# ---------------------------------------------------------------------------

# Database (Postgres — Neon / Supabase / Railway / Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/aneem?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Qikink (Print-on-demand + fulfillment — ORDERS only, not a product/catalog
# API: confirmed against Qikink's real API docs, the only endpoints are
# Authorization + Orders (Create Order, list, single). Product catalog data
# does not come from Qikink's API at all — see /founder/products and the
# CSV-import discussion for how the real 450+ catalog gets in.
# Get ClientId/client_secret from dashboard.qikink.com > Integration > Custom API.
# Live API access has to be explicitly requested from that same page.
QIKINK_CLIENT_ID=""
QIKINK_CLIENT_SECRET=""
QIKINK_API_BASE_URL="https://sandbox.qikink.com/api"
# Shared secret used to verify inbound Qikink webhook signatures
QIKINK_WEBHOOK_SECRET=""
# When true (or when credentials above are empty), the integration layer
# serves fixture data from src/lib/qikink/mock-data.ts instead of calling
# the real API — lets the whole app run end-to-end with no live account.
QIKINK_USE_MOCK="true"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Notifications (order updates via WhatsApp + email)
# WhatsApp Cloud API (Meta) — future-ready, safe to leave blank
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
# Transactional email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Aneem <orders@aneem.in>"

# Cron protection — required header value for /api/cron/* routes
CRON_SECRET="generate-a-random-string"

# AI Style Assistant (optional — falls back to rule-based recommender if unset)
ANTHROPIC_API_KEY=""

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Future integrations (not required for launch)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
META_CONVERSIONS_API_TOKEN=""

# ---------------------------------------------------------------------------
# Founder Portal — completely separate auth realm from the storefront.
# ---------------------------------------------------------------------------

# Host that serves the Founder Portal. Requests to any other host for
# /founder or /api/founder* routes get a plain 404 (see src/middleware.ts).
# Dev default works out of the box: visit http://founder.localhost:3000
FOUNDER_PORTAL_HOST="founder.localhost:3000"

# Separate JWT signing secret from NEXTAUTH_SECRET — never reuse the value.
FOUNDER_NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Used once by `npm run db:seed-founder` to create the initial founder
# account (no public registration route exists — by design). Unset these
# after running the script; they're not read anywhere else.
FOUNDER_NAME="Founder"
FOUNDER_EMAIL=""
FOUNDER_PASSWORD=""

# Marketing Dashboard integrations — all optional, mock data shown until set
META_ADS_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""
GA4_PROPERTY_ID=""
GOOGLE_SERVICE_ACCOUNT_JSON=""
SEARCH_CONSOLE_SITE_URL=""
CLARITY_PROJECT_ID=""
MARKETING_USE_MOCK="true"

# ---------------------------------------------------------------------------
# AI Marketing Studio (Founder Portal) — content/creative generation engine.
# ---------------------------------------------------------------------------

# Reuses ANTHROPIC_API_KEY above for all text + vision generation (product
# analysis, captions, hashtags, carousels, stories, descriptions, ad copy,
# WhatsApp/email campaigns, offer suggestions, bundle creative, reel briefs,
# thumbnail concepts, content scoring). Every generator falls back to a
# realistic mock when it's unset, so the Studio works end-to-end with no key.

# Vercel Blob — stores uploaded product photos and AI-enhanced/generated
# images. Required for the Studio's asset uploader to work at all (no mock
# fallback for storage itself — get a token from Vercel Storage > Blob).
BLOB_READ_WRITE_TOKEN=""

# Hosted video-assembly API for the AI Reel Generator (e.g. Creatomate,
# Shotstack, JSON2Video). We only call a JSON render API — no FFmpeg/worker
# infra of our own, since Vercel serverless can't run FFmpeg or hold state.
# Without these, the Reel Generator still produces a full real creative
# brief (scenes, voiceover script, music suggestion) via Claude — it just
# won't render an actual MP4.
VIDEO_RENDER_API_KEY=""
VIDEO_RENDER_API_BASE_URL=""

# Image generation/enhancement API (e.g. a hosted Stable Diffusion/Flux
# endpoint) for AI Image Enhancement (background removal, mockups, hero
# shots, etc). Without these, enhancement operations are recorded but return
# the original source image with isMock: true instead of a new render.
IMAGE_API_KEY=""
IMAGE_API_BASE_URL=""
